	<parameter name="datestart" class="java.lang.String">
		<defaultValueExpression><![CDATA[DATEFORMAT(DATE(YEAR(TODAY( )),1,1),"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="dateend" class="java.lang.String">
		<defaultValueExpression><![CDATA[DATEFORMAT(TODAY() ,"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="stmtno" class="java.lang.String"/>
	<parameter name="txndesc" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[select 
   row_number() over (order by t0.dt_statement desc, t0.stmt_no desc) as no, 
   t0.stmt_no as stmtno, 
   t1.file_nm as statement_filenm, 
   t0.dt_statement as dtstatement, 
   sum(t2.txn_amt) as txnamt,
   sum(t2.mdr_amt) as mdramt,
   sum(t2.sst_amt) as sstamt,
   t0.total_txn as totaltxn,
   t4.txn_desc as txndesc,
   t4.dt_posting as dtposting,
   t4.credit as credit,
   t5.file_nm as bankstatement_filenm
   from rms_rc_pg t0 
   left outer join rms_rc_pgdoc t1 ON t1.rc_pg_id = t0.rc_pg_id
   left outer join rms_rc_pgtxn t2 ON t2.rc_pg_id = t0.rc_pg_id
   left outer join rms_rc_bank t3 ON  t3.rc_pg_id = t0.rc_pg_id
   left outer join rms_rc_banktxn t4 ON t4.rc_bank_id = t3.rc_bank_id
   left outer join rms_rc_bankdoc t5 ON t5.rc_bankdoc_id = t4.rc_bankdoc_id
   where t2.txn_cd = 'Settlement'
   and t3.recon_status='SBSR'
   and date(t0.dt_statement) >= MDY(MONTH(date($P{datestart})), DAY(date($P{datestart})), YEAR(date($P{datestart}))) 
   and date(t0.dt_statement) <= MDY(MONTH(date($P{dateend})), DAY(date($P{dateend})), YEAR(date($P{dateend}))) 
   and ($P{stmtno} is null or $P{stmtno} = '' or t0.stmt_no like '%' || $P{stmtno} ||'%')
   and ($P{txndesc} is null or $P{txndesc} = '' or t4.txn_desc like '%' || $P{txndesc} ||'%')
   group by stmtno, statement_filenm,  dtstatement,  totaltxn, txndesc, dtposting,
   credit, bankstatement_filenm]]>
	</queryString>
