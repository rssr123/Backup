	<parameter name="dateend" class="java.lang.String">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[DATEFORMAT(TODAY( ),"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="datestart" class="java.lang.String">
		<defaultValueExpression><![CDATA[DATEFORMAT(DATE(YEAR(TODAY( ))-1,1,1),"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[select  NVL(t12.nm_en,'Unknown') as paymentmethod, NVL(t2.recCount,0) as trx1, NVL(t2.totalRM,0) as rm1, NVL(t3.recCount,0) as trx2, NVL(t3.totalRM,0) as rm2, NVL(t2.totalRM,0) - NVL(t3.totalRM,0) as var1, 
	    case when NVL(t3.totalRM,0) = 0 and NVL(t2.totalRM,0) = 0 then 0.00 when NVL(t3.totalRM,0) = 0 then 100.00 when NVL(t2.totalRM,0) = 0 then -100.00 else ((t2.totalRM - t3.totalRM)/t3.totalRM)*100 end as var2,
	    t2.ss_cd_1 as ss_cd
from rms_mtt_pg t10  
	left join rms_param t12 on t10.pg_pymt_method = t12.param_cd and t12.param_grp_nm='PGPaymentMethod'
	left join(select '1' as a, t1.pg_pymt_method, count(t1.mtt_id) as recCount, sum(t1.pg_pymt_amt) as totalRM, t0.ss_cd as ss_cd_1 from rms_mtt t0 left join rms_mtt_pg t1 on t0.mtt_id = t1.mtt_id
	   			where date(t1.pymt_submit_dt) >= MDY(MONTH(date($P{datestart})), 1, YEAR(date($P{datestart}))) and date(t1.pymt_submit_dt) <= LAST_DAY(date($P{dateend}))
	   			and t0.order_status='P' and t1.pg_txn_status = 0 and t1.pg_txn_id is not null group by t1.pg_pymt_method, t0.ss_cd) 
	   			t2 on t10.pg_pymt_method = t2.pg_pymt_method
	left join(select '1' as b, t5.pg_pymt_method, count(t5.mtt_id) as recCount, sum(t5.pg_pymt_amt) as totalRM, t4.ss_cd as ss_cd_2 from rms_mtt t4 left join rms_mtt_pg t5 on t4.mtt_id = t5.mtt_id
	  			where date(t5.pymt_submit_dt) >= MDY(MONTH(date($P{datestart})), 1, YEAR(date($P{datestart}))) - 1 units YEAR and date(t5.pymt_submit_dt) <= LAST_DAY(date($P{dateend}) - 1 units YEAR) 
	   			and t4.order_status='P' and t5.pg_txn_status = 0 and t5.pg_txn_id is not null group by t5.pg_pymt_method, t4.ss_cd) 
	   			t3 on t10.pg_pymt_method = t3.pg_pymt_method  and t2.ss_cd_1 = t3.ss_cd_2
	where t10.pg_pymt_method != 'ANY' and (a = '1' or b = '1')
	group by paymentmethod, trx1, rm1, trx2, rm2, var1, var2, ss_cd
	order by paymentmethod;]]>
	</queryString>
