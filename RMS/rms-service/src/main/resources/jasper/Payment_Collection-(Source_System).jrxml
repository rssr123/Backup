				<textFieldExpression><![CDATA["Duration: " + 
($P{datestart}.split("-")[1].equals("01") ? "January" :
$P{datestart}.split("-")[1].equals("02") ? "February" :
$P{datestart}.split("-")[1].equals("03") ? "March" :
$P{datestart}.split("-")[1].equals("04") ? "April" :
$P{datestart}.split("-")[1].equals("05") ? "May" :
$P{datestart}.split("-")[1].equals("06") ? "June" :
$P{datestart}.split("-")[1].equals("07") ? "July" :
$P{datestart}.split("-")[1].equals("08") ? "August" :
$P{datestart}.split("-")[1].equals("09") ? "September" :
$P{datestart}.split("-")[1].equals("10") ? "October" :
$P{datestart}.split("-")[1].equals("11") ? "November" : "December")
+ " till " +
($P{dateend}.split("-")[1].equals("01") ? "January" :
$P{dateend}.split("-")[1].equals("02") ? "February" :
$P{dateend}.split("-")[1].equals("03") ? "March" :
$P{dateend}.split("-")[1].equals("04") ? "April" :
$P{dateend}.split("-")[1].equals("05") ? "May" :
$P{dateend}.split("-")[1].equals("06") ? "June" :
$P{dateend}.split("-")[1].equals("07") ? "July" :
$P{dateend}.split("-")[1].equals("08") ? "August" :
$P{dateend}.split("-")[1].equals("09") ? "September" :
$P{dateend}.split("-")[1].equals("10") ? "October" :
$P{dateend}.split("-")[1].equals("11") ? "November" : "December")
+ " " + $P{dateend}.split("-")[0]]]></textFieldExpression>
