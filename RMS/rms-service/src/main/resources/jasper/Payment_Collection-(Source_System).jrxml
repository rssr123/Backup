	</field>
	<sortField name="ss_cd"/>
	<variable name="TRX_1" class="java.math.BigDecimal" resetType="Group" resetGroup="ss_cd" calculation="Sum">
		<variableExpression><![CDATA[$F{trx1}]]></variableExpression>
	</variable>
	<variable name="TRX_2" class="java.math.BigDecimal" resetType="Group" resetGroup="ss_cd" calculation="Sum">
		<variableExpression><![CDATA[$F{trx2}]]></variableExpression>
	</variable>
	<variable name="RM_1" class="java.math.BigDecimal" resetType="Group" resetGroup="ss_cd" calculation="Sum">
		<variableExpression><![CDATA[$F{rm1}]]></variableExpression>
	</variable>
	<variable name="RM_2" class="java.math.BigDecimal" resetType="Group" resetGroup="ss_cd" calculation="Sum">
		<variableExpression><![CDATA[$F{rm2}]]></variableExpression>
	</variable>
	<variable name="Var_1" class="java.math.BigDecimal" resetType="Group" resetGroup="ss_cd" calculation="Sum">
		<variableExpression><![CDATA[$F{var1}]]></variableExpression>
	</variable>
	<variable name="Var_2" class="java.math.BigDecimal" resetType="Group" resetGroup="ss_cd">
		<variableExpression><![CDATA[$V{Var_1}.compareTo(new BigDecimal("0")) == 0 ? new BigDecimal("0") :
$V{RM_2}.compareTo(new BigDecimal("0")) == 0 ? new BigDecimal("100") : $V{Var_1}.multiply(new BigDecimal("100")).divide($V{RM_2}, 2, RoundingMode.HALF_UP)]]></variableExpression>
	</variable>
