	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="297"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="695"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="informix"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.key.PDFOnly"/>
	<property name="net.sf.jasperreports.export.csv.exclude.key.PDFOnly"/>
