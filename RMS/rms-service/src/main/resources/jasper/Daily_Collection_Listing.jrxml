	<parameter name="datestart" class="java.lang.String">
		<defaultValueExpression><![CDATA[DATEFORMAT(DATE(YEAR(TODAY( )),1,1),"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="dateend" class="java.lang.String">
		<defaultValueExpression><![CDATA[DATEFORMAT(TODAY() ,"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="ornno" class="java.lang.String">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="pgpymtid" class="java.lang.String"/>
	<parameter name="pgtxnid" class="java.lang.String"/>
	<parameter name="pgtxnstatus" class="java.lang.Integer"/>
	<parameter name="pgtxnmsg" class="java.lang.String"/>
	<parameter name="rcptno" class="java.lang.String"/>
	<parameter name="stmtno" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[with cte as (
  select
   t0.orn_no as ornno, 
   t0.cust_nm as custnm, 
   cast(t0.cust_addr_1 || ', ' || t0.cust_addr_2 || ', ' || t0.cust_addr_3 AS lvarchar(460)) AS custaddr,
   t0.cust_email as custemail, 
   t0.cust_phone as custphone, 
   t2.fee_detail_id as feedetailid, 
   t3.fee_detail_nm_e as feedetailnme, 
   t4.fee_grp_nm_en as feegrpnmen, 
   t2.item_desc as itemdesc, 
   t8.nm_en as entitytype,
   t2.entity_no as entityno, 
   t2.entity_nm as entitynm,
   t2.unit_fee as unitfee, 
   t2.qty as qty, 
   t2.tax_amt as taxamt, 
   (t2.unit_fee * t2.qty) as itemamt, 
   t2.gross_amt as grossamt,
   t2.disc_amt as discamt, 
   t2.net_amt as totalbeforebankcharge,
   t2.line_no AS itemlineno,
   t1.pg_txn_id as pgtxnid, 
   t1.pymt_submit_dt as pymtsubmitdt, 
   t9.nm_en as pgpymtmethod,
   t1.pg_pymt_amt as transamount_pgpymtamt, 
   t1.pg_txn_status as pgtxnstatus, 
   t1.pg_txn_msg as pgtxnmsg,
   t5.rcpt_no as rcptno, t5.rcpt_dt as rcptdt, 
   t1.pg_pymt_amt as receiptamount_pgpymtamt, 
   t6.dt_txn as dttxn, 
   t7.stmt_no as stmtno, 
   t7.dt_statement as dtstatement, 
   t6.mdr_amt as mdramt, 
   t6.sst_amt as sstamt, 
   t6.net_amt as netamt
   from rms_mtt t0 
   left outer join rms_mtt_pg t1 on t0.mtt_id = t1.mtt_id 
   left outer join rms_mtt_item t2 on t2.mtt_id= t1.mtt_id  
   left outer join rms_mft t3 on t2.fee_detail_pk = t3.fee_detail_pk
   left outer join rms_fee_group t4 on t3.fee_grp_id = t4.fee_grp_id
   left outer join rms_mtt_rcpt t5 on t5.mtt_pg_id = t1.mtt_pg_id
   left outer join rms_rc_pgtxn t6 on t1.pg_txn_id=t6.txn_id
   left outer join rms_rc_pg t7 on t6.rc_pg_id = t7.rc_pg_id
   left outer join rms_param t8 on t8.param_cd = t2.entity_type and t8.param_grp_nm = 'EntityType'
   left outer join rms_param t9 on t9.param_cd = t1.pg_pymt_method and t9.param_grp_nm = 'PGPaymentMethod'
   where 
   date(t1.pymt_submit_dt) >= MDY(MONTH(date($P{datestart})), DAY(date($P{datestart})), YEAR(date($P{datestart}))) 
   and date(t1.pymt_submit_dt) <= MDY(MONTH(date($P{dateend})), DAY(date($P{dateend})), YEAR(date($P{dateend}))) 
   and ($P{ornno} is null or $P{ornno} = '' or t0.orn_no like '%' || $P{ornno} ||'%') 
   and ($P{pgpymtid} is null or $P{pgpymtid} = '' or t1.pg_pymt_id like '%' || $P{pgpymtid} ||'%')
   and ($P{pgtxnid} is null or $P{pgtxnid} = '' or t1.pg_txn_id like '%' || $P{pgtxnid} ||'%')
   and ($P{pgtxnstatus} is null or $P{pgtxnstatus} = '' or $P{pgtxnstatus} = 999 or t1.pg_txn_status = $P{pgtxnstatus})
   and ($P{pgtxnmsg} is null or $P{pgtxnmsg} = '' or t1.pg_txn_msg like '%' || $P{pgtxnmsg} ||'%')
   and ($P{rcptno} is null or $P{rcptno} = '' or t5.rcpt_no like '%' || $P{rcptno} ||'%')
   and ($P{stmtno} is null or $P{stmtno} = '' or t7.stmt_no like '%' || $P{stmtno} ||'%')
   and t2.status ='A' and t3.status ='A' and t4.status ='A' and t1.pg_txn_status = 0
   order by  ornno,pgtxnid,t2.line_no
   )
   select  
   row_number() over (order by ornno desc,pgtxnid,pymtsubmitdt,itemlineno) as no, 
   ornno, 
   row_number() over (partition by ornno) as rownumber,
   custnm, 
   custaddr,
   custemail, 
   custphone, 
   feedetailid, 
   feedetailnme, 
   feegrpnmen, 
   itemdesc, 
   entitytype, 
   entityno, 
   entitynm,
   unitfee, 
   qty, 
   taxamt, 
   itemamt, 
   grossamt,
   discamt, 
   totalbeforebankcharge,
   itemlineno,
   case 
       when itemlineno = 1 then pgtxnid
       else null
   end as pgtxnid,
   case 
       when itemlineno = 1 then pymtsubmitdt
       else null
   end as pymtsubmitdt,
   case 
       when itemlineno = 1 then pgpymtmethod
       else null
   end as pgpymtmethod,
   case 
       when itemlineno = 1 then transamount_pgpymtamt
       else null
   end as transamount_pgpymtamt,
   case 
       when itemlineno = 1 then pgtxnstatus
       else null
   end as pgtxnstatus,
   case 
       when itemlineno = 1 then pgtxnmsg
       else null
   end as pgtxnmsg,
   case 
       when itemlineno = 1 then rcptno
       else null
   end as rcptno,
   case 
       when itemlineno = 1 then rcptdt
       else null
   end as rcptdt,
   case 
       when itemlineno = 1 then receiptamount_pgpymtamt
       else null
   end as receiptamount_pgpymtamt,
   case 
       when itemlineno = 1 then dttxn
       else null
   end as dttxn,
   case 
       when itemlineno = 1 then stmtno
       else null
   end as stmtno,
   case 
       when itemlineno = 1 then dtstatement
       else null
   end as dtstatement,
   case 
        when itemlineno = 1 then mdramt
   else null
   end as mdramt,
   case 
       when itemlineno = 1 then sstamt
       else null
   end as sstamt,
   case 
       when itemlineno = 1 then netamt
       else null
   end as netamt
 from cte]]>
	</queryString>
