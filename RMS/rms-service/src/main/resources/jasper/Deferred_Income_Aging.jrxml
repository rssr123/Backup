	<queryString language="SQL">
		<![CDATA[WITH cte1 AS (
  SELECT t4.batch_no, t4.fms_ref_no,
    CAST(SUBSTRING(t4.attr_ext_ref_no FROM 4 FOR INSTR(t4.attr_ext_ref_no, '-', 4) - 4) AS serial8) AS extracted_di_id
FROM rms_fms_jn_h t4
WHERE t4.attr_ext_ref_no MATCHES 'DI-*'
),
cte2 AS (
    SELECT 
        t0.entity_no AS entityno,
        t4.nm_en as entitytype,
        t1.entity_nm AS entitynm,
        t0.dt_expiry AS dtexpiry,
        t6.nm_en AS txntype,
        t0.bal_di_amt AS baldiamt,
        t2.rcpt_dt AS rcptdt,
        t0.dt_effective AS dteffective,
        t0.dt_approval AS dtapproval,
        t0.dt_termination AS dttermination,
        t0.total_fee AS totalfee,
        t2.rcpt_no AS rcptno,
        t5.nm_en AS status,
        t3.dt_txn AS dttxn,
        t0.next_calc_dt AS nextcalcdt,
        c1.batch_no AS batchno,
        c1.fms_ref_no AS fmsrefno,
        FLOOR(t0.bal_di_amt / t0.unit_fee) AS yearleft
    FROM rms_di t0
    LEFT OUTER JOIN rms_mtt_item t1 ON t1.item_ref_no = t0.item_ref_no
    LEFT OUTER JOIN rms_mtt_rcpt t2 ON t2.mtt_id = t1.mtt_id
    LEFT OUTER JOIN rms_di_a t3 ON t3.di_id = t0.di_id
    LEFT OUTER JOIN cte1 c1 ON c1.extracted_di_id = t0.di_id
    left outer join rms_param t4 on t4.param_cd = t0.entity_type and t4.param_grp_nm = 'EntityType'
    left outer join rms_param t5 on t5.param_cd = t0.status and t5.param_grp_nm = 'DI-Status'
    left outer join rms_param t6 on t6.param_cd = t0.txn_type and t6.param_grp_nm = 'DI-TxnType'
    WHERE 
        DATE(t2.rcpt_dt) <= MDY(MONTH(DATE($P{receiptdateend})), DAY(DATE($P{receiptdateend})), YEAR(DATE($P{receiptdateend})))
        AND DATE(t0.dt_effective) >= MDY(MONTH(DATE($P{effectivedatestart})), DAY(DATE($P{effectivedatestart})), YEAR(DATE($P{effectivedatestart})))
        AND DATE(t0.dt_effective) <= MDY(MONTH(DATE($P{effectivedateend})), DAY(DATE($P{effectivedateend})), YEAR(DATE($P{effectivedateend})))
        AND (
            $P{distatus} IS NULL OR $P{distatus} = '' OR $P{distatus} = 'all' OR
            t0.status IN (
                $P{distatus}, 
                CASE 
                    WHEN $P{inctermstatus} = 1 THEN 'T' 
                    ELSE NULL 
                END
            )
        )
        AND ($P{entitytype} IS NULL OR $P{entitytype} = '' OR $P{entitytype} = 'all' OR t0.entity_type = $P{entitytype})
        AND ($P{entitynm} IS NULL OR $P{entitynm} = '' OR t1.entity_nm LIKE '%' || $P{entitynm} || '%')
        AND ($P{txntype} IS NULL OR $P{txntype} = '' or $P{txntype} = 'all' OR t0.txn_type = $P{txntype})
        AND ($P{expirydatestart} IS NULL OR $P{expirydatestart} = '' OR DATE(t0.dt_expiry) >= MDY(MONTH(DATE($P{expirydatestart})), DAY(DATE($P{expirydatestart})), YEAR(DATE($P{expirydatestart}))))
        AND ($P{expirydateend} IS NULL OR $P{expirydateend} = '' OR DATE(t0.dt_expiry) <= MDY(MONTH(DATE($P{expirydateend})), DAY(DATE($P{expirydateend})), YEAR(DATE($P{expirydateend}))))
        AND ($P{approvaldatestart} IS NULL OR $P{approvaldatestart} = '' OR DATE(t0.dt_approval) >= MDY(MONTH(DATE($P{approvaldatestart})), DAY(DATE($P{approvaldatestart})), YEAR(DATE($P{approvaldatestart}))))
        AND ($P{approvaldateend} IS NULL OR $P{approvaldateend} = '' OR DATE(t0.dt_approval) <= MDY(MONTH(DATE($P{approvaldateend})), DAY(DATE($P{approvaldateend})), YEAR(DATE($P{approvaldateend}))))
        AND ($P{terminationdatestart} IS NULL OR $P{terminationdatestart} = '' OR DATE(t0.dt_termination) >= MDY(MONTH(DATE($P{terminationdatestart})), DAY(DATE($P{terminationdatestart})), YEAR(DATE($P{terminationdatestart}))))
        AND ($P{terminationdateend} IS NULL OR $P{terminationdateend} = '' OR DATE(t0.dt_termination) <= MDY(MONTH(DATE($P{terminationdateend})), DAY(DATE($P{terminationdateend})), YEAR(DATE($P{terminationdateend}))))
        AND ($P{batchno} IS NULL OR $P{batchno} = '' OR c1.batch_no LIKE '%' || $P{batchno} || '%') 
        AND ($P{fmsrefno} IS NULL OR $P{fmsrefno} = '' or c1.fms_ref_no LIKE '%' || $P{fmsrefno} || '%') 
        AND t0.bal_di_amt > 0
    GROUP BY 
        t0.entity_no, t4.nm_en, t1.entity_nm, t0.dt_expiry, t6.nm_en, t0.bal_di_amt, t2.rcpt_dt, 
        t0.dt_effective, t0.dt_approval, t0.dt_termination, t0.total_fee, t2.rcpt_no, t5.nm_en, t3.dt_txn, 
        t0.next_calc_dt, c1.batch_no, c1.fms_ref_no, yearleft
)
SELECT 
    ROW_NUMBER() OVER (ORDER BY dteffective DESC, entityno DESC, rcptdt DESC, dtexpiry DESC, dttermination DESC) AS no, 
    entityno,
    entitytype,
    entitynm,
    dtexpiry,
    txntype,
    baldiamt,
    rcptdt,
    dteffective,
    dtapproval,
    dttermination,
    totalfee,
    rcptno,
    status,
    dttxn,
    nextcalcdt,
    batchno,
    fmsrefno,
    CASE 
        WHEN yearleft = 1 THEN baldiamt
        ELSE NULL
    END AS year1,
    CASE 
        WHEN yearleft = 2 THEN baldiamt
        ELSE NULL
    END AS year2,
    CASE 
        WHEN yearleft = 3 THEN baldiamt
        ELSE NULL
    END AS year3,
    CASE 
        WHEN yearleft = 4 THEN baldiamt
        ELSE NULL
    END AS year4,
    CASE 
        WHEN yearleft = 5 THEN baldiamt
        ELSE NULL
    END AS year5
    from cte2]]>
	</queryString>
