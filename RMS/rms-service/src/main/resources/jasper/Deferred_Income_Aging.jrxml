	<variable name="TotalDeferred" class="java.math.BigDecimal" incrementType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{year1} == null && $F{year2} == null && $F{year3} == null && $F{year4} == null && $F{year5} == null ? 
    null : 
    (
        ($F{year1} != null ? (java.math.BigDecimal) $F{year1} : java.math.BigDecimal.ZERO)
        .add($F{year2} != null ? (java.math.BigDecimal) $F{year2} : java.math.BigDecimal.ZERO)
        .add($F{year3} != null ? (java.math.BigDecimal) $F{year3} : java.math.BigDecimal.ZERO)
        .add($F{year4} != null ? (java.math.BigDecimal) $F{year4} : java.math.BigDecimal.ZERO)
        .add($F{year5} != null ? (java.math.BigDecimal) $F{year5} : java.math.BigDecimal.ZERO)
    )]]></variableExpression>
	</variable>
