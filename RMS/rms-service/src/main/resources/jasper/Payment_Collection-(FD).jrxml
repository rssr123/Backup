	<parameter name="dateend" class="java.lang.String">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[DATEFORMAT(TODAY( ),"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="datestart" class="java.lang.String">
		<defaultValueExpression><![CDATA[DATEFORMAT(DATE(YEAR(TODAY( )),1,1),"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="paymentmode" class="java.lang.String">
		<defaultValueExpression><![CDATA["CC"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH RankedData AS (
    SELECT  
        t3.fee_detail_id,
        t3.fee_detail_nm_e,
        t3.ledger_cd, 
        t5.nm_en,
        NVL(COUNT(1), 0) AS trx, 
        SUM(t1.net_amt) AS rm,
        ROW_NUMBER() OVER (PARTITION BY t3.fee_detail_id, t3.fee_detail_nm_e, t3.ledger_cd ORDER BY t5.nm_en) AS row_num
    FROM 
        rms_mtt_item t1 
        LEFT OUTER JOIN rms_mtt t2 ON t1.mtt_id = t2.mtt_id
        LEFT OUTER JOIN rms_mft t3 ON t1.fee_detail_pk = t3.fee_detail_pk
        LEFT OUTER JOIN rms_mtt_pg t4 ON t1.mtt_id = t4.mtt_id
        LEFT OUTER JOIN rms_param t5 ON t4.pg_pymt_method = t5.param_cd
    WHERE 
        t2.order_status = 'P'
        AND INSTR($P{paymentmode}, t5.param_cd) > 0
        AND t5.param_grp_nm = 'PGPaymentMethod'
        AND DATE(t4.pymt_submit_dt) >= DATE($P{datestart}) 
        AND DATE(t4.pymt_submit_dt) <= LAST_DAY(DATE($P{dateend}))
    GROUP BY 
        t3.fee_detail_id, 
        t3.fee_detail_nm_e, 
        t3.ledger_cd, 
        t5.nm_en
)
SELECT 
    fee_detail_id,
    CASE WHEN row_num = 1 THEN fee_detail_id ELSE NULL END AS fee_detail_id_display,
    CASE WHEN row_num = 1 THEN fee_detail_nm_e ELSE NULL END AS fee_detail_nm_e,
    CASE WHEN row_num = 1 THEN ledger_cd ELSE NULL END AS ledger_cd,
    
   
    nm_en,
    trx,
    rm
FROM RankedData
ORDER BY fee_detail_id, nm_en desc;]]>
	</queryString>
