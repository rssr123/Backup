	<parameter name="datestart" class="java.lang.String">
		<defaultValueExpression><![CDATA[DATEFORMAT(DATE(YEAR(TODAY( )),1,1),"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="dateend" class="java.lang.String">
		<defaultValueExpression><![CDATA[DATEFORMAT(TODAY() ,"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="ornno" class="java.lang.String"/>
	<parameter name="pgpymtid" class="java.lang.String"/>
	<parameter name="pgtxnid" class="java.lang.String"/>
	<parameter name="rcptno" class="java.lang.String"/>
	<parameter name="stmtno" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[select
   ROW_NUMBER() OVER (ORDER BY t2.orn_no desc, t1.pg_txn_id desc, t1.pymt_submit_dt) AS no,
   t2.orn_no as ornno,
   t2.cust_nm as custnm,
   CAST(t2.cust_addr_1 || ', ' || t2.cust_addr_2 || ', ' || t2.cust_addr_3 AS lvarchar(460)) AS custaddr,
   t2.cust_email as custemail,
   t2.cust_phone as custphone,
   (t3.unit_fee * t3.qty) as itemamt,
   t3.tax_amt as taxamt,
   t3.gross_amt as grossamt,
   t3.disc_amt as discamt,
   t3.net_amt as totalbeforebankcharge,
   t1.pg_txn_id as pgtxnid,
   t1.pymt_submit_dt as pymtsubmitdt,
   t14.nm_en as pgpymtmethod,
   t1.pg_pymt_amt as transamount_pgpymtamt,
   t1.pg_txn_status as pgtxnstatus,
   t1.pg_txn_msg as pgtxnmsg,
   t4.rcpt_no as rcptno,
   t4.rcpt_dt as rcptdt,
   t1.pg_pymt_amt as receiptamount_pgpymtamt,
   t0.dt_txn as dttxn,
   t5.stmt_no as stmtno,
   t5.dt_statement as dtstatement,
   t0.mdr_amt as mdramt,
   t0.sst_amt as sstamt,
   t0.net_amt as netamt,
   t15.nm_en as subcriteria,
   t7.rms_batch_no AS rmsarinvbatch_rmsbatchno,
   t7.fms_ref_no AS fmsarinvrefno_fmsrefno,
   t9.rms_batch_no AS rmsarrcptbatchno_rmsbatchno,
   t9.fms_ref_no AS fmsarrcptrefno_fmsrefno,
   t11.rms_batch_no as rmscreditnotebatchno_rmsbatchno,
   t11.fms_ref_no as fmscreditnoterefno_fmsrefno,
   t13.rms_batch_no as rmsdebitnotebatchno_rmsbatchno,
   t13.fms_ref_no as fmsdebitnoterefno_fmsprefno
   from rms_rc_pgtxn t0
   left outer join rms_mtt_pg t1 on t0.txn_id = t1.pg_txn_id
   left outer join rms_mtt t2 on t2.mtt_id = t1.mtt_id   
   left outer join rms_mtt_item t3 on t3.mtt_id = t1.mtt_id
   left outer join rms_mtt_rcpt t4 on t4.mtt_pg_id = t1.mtt_pg_id
   left outer join rms_rc_pg t5 on t5.rc_pg_id = t0.rc_pg_id
   left outer join rms_fms_ari_b t6 on t6.mtt_pg_id = t1.mtt_pg_id
   LEFT OUTER JOIN rms_fms_ari_h t7 on t7.ari_hid = t6.ari_hid
   LEFT OUTER JOIN rms_fms_arr_b t8 ON t8.mtt_pg_id = t1.mtt_pg_id
   LEFT OUTER JOIN rms_fms_arr_h t9 ON t9.arr_hid = t8.arr_hid
   left outer join rms_fms_crmemo_b t10 on t10.mtt_pg_id = t1.mtt_pg_id
   left outer join rms_fms_crmemo_h t11 on t11.crmemo_hid = t10.crmemo_hid
   left outer join rms_fms_drmemo_b t12 on t12.mtt_pg_id = t1.mtt_pg_id
   left outer join rms_fms_drmemo_h t13 on t13.drmemo_hid = t12.drmemo_hid
   left outer join rms_param t14 on t14.param_cd = t1.pg_pymt_method and t14.param_grp_nm = 'PGPaymentMethod'
   left outer join rms_param t15 on t15.param_cd = t0.sub_criteria and t15.param_grp_nm = 'PGRecon-PGSubCri'
   where
   ($P{datestart} is null or $P{datestart}='' or (date(t1.pymt_submit_dt) >= MDY(MONTH(date($P{datestart})), DAY(date($P{datestart})), YEAR(date($P{datestart}))))) 
   and ($P{dateend} is null or $P{dateend}='' or (date(t1.pymt_submit_dt) <= MDY(MONTH(date($P{dateend})), DAY(date($P{dateend})), YEAR(date($P{dateend}))))) 
   and ($P{ornno} is null or $P{ornno} = '' or t2.orn_no  like '%' || $P{ornno} ||'%')
   and ($P{pgpymtid} is null or $P{pgpymtid} = '' or t1.pg_pymt_id  like '%' || $P{pgpymtid} ||'%')
   and ($P{pgtxnid} is null or $P{pgtxnid} = '' or t1.pg_txn_id  like '%' || $P{pgtxnid} ||'%')
   and ($P{rcptno} is null or $P{rcptno} = '' or t4.rcpt_no  like '%' || $P{rcptno} ||'%')
   and ($P{stmtno} is null or $P{stmtno} = '' or t5.stmt_no  like '%' || $P{stmtno} ||'%')
   group by ornno, custnm, custaddr, custemail, custphone, itemamt, taxamt, grossamt, discamt, totalbeforebankcharge,
   pgtxnid, pymtsubmitdt, pgpymtmethod, transamount_pgpymtamt, pgtxnstatus, pgtxnmsg, rcptno, rcptdt, receiptamount_pgpymtamt,
   dttxn, stmtno, dtstatement, mdramt, sstamt, netamt, subcriteria, rmsarinvbatch_rmsbatchno, fmsarinvrefno_fmsrefno, rmsarrcptbatchno_rmsbatchno,
   fmsarrcptrefno_fmsrefno, rmscreditnotebatchno_rmsbatchno, fmscreditnoterefno_fmsrefno, rmsdebitnotebatchno_rmsbatchno,
   fmsdebitnoterefno_fmsprefno]]>
	</queryString>
