	<parameter name="settlementdate" class="java.lang.String">
		<defaultValueExpression><![CDATA[DATEFORMAT(DATE(YEAR(TODAY( )),1,1),"yyyy-MM-dd")]]></defaultValueExpression>
	</parameter>
	<parameter name="orderreferenceno" class="java.lang.String"/>
	<parameter name="subcriteria" class="java.lang.Integer"/>
	<parameter name="receiptnumber" class="java.lang.String"/>
	<parameter name="pgtransactionid" class="java.lang.String"/>
	<parameter name="statementno" class="java.lang.String"/>
	<parameter name="checkduplicate" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[WITH CTE AS (
    SELECT 
        mtt_id,
        COUNT(mtt_pg_id) AS mtt_pg_count
    FROM 
        rms_mtt_pg
    GROUP BY 
        mtt_id
)

SELECT 
    ROW_NUMBER() OVER (ORDER BY t3.orn_no DESC) AS no,
    t3.orn_no AS ornno, 
    t4.rcpt_no AS rcptno, 
    t2.pg_txn_id AS pgtxnid, 
    t4.rcpt_dt AS rcptdt, 
    t0.stmt_no AS stmtno, 
    t0.dt_statement AS dtstatement, 
    t5.mdr_amt AS mdramt,
    t7.rms_batch_no AS rmsbatchnocr, 
    t9.rms_batch_no AS rmsbatchnodr, 
    t5.txn_amt AS txnamt, 
    t2.pg_pymt_amt AS pgpymtamt
FROM 
    rms_rc_pg t0
LEFT OUTER JOIN 
    rms_rc_pgmtt t1 ON t0.rc_pg_id = t1.rc_pg_id
LEFT OUTER JOIN 
    rms_mtt_pg t2 ON t1.mtt_pg_id = t2.mtt_pg_id
LEFT OUTER JOIN 
    rms_mtt t3 ON t2.mtt_id = t3.mtt_id
LEFT OUTER JOIN 
    rms_mtt_rcpt t4 ON t1.mtt_pg_id = t4.mtt_pg_id
LEFT OUTER JOIN 
    rms_rc_pgtxn t5 ON t2.mtt_pg_id = t5.mtt_pg_id
LEFT OUTER JOIN 
    rms_fms_crmemo_b t6 ON t1.mtt_pg_id = t6.mtt_pg_id
LEFT OUTER JOIN 
    rms_fms_crmemo_h t7 ON t6.crmemo_hid = t7.crmemo_hid
LEFT OUTER JOIN 
    rms_fms_drmemo_b t8 ON t1.mtt_pg_id = t8.mtt_pg_id
LEFT OUTER JOIN 
    rms_fms_drmemo_h t9 ON t8.drmemo_hid = t9.drmemo_hid
JOIN 
    CTE t10 ON t3.mtt_id = t10.mtt_id

    
    WHERE
    ($P{settlementdate} IS NULL OR $P{settlementdate} = '' OR DATE(t0.dt_settlement) = MDY(MONTH(DATE($P{settlementdate})), DAY(DATE($P{settlementdate})), YEAR(DATE($P{settlementdate}))))
    AND ($P{orderreferenceno} IS NULL OR $P{orderreferenceno} = '' OR t3.orn_no LIKE '%' || $P{orderreferenceno} || '%')
    AND ((
        ($P{subcriteria} IS NULL OR $P{subcriteria} = '' or $P{subcriteria} = '0')
        AND (t5.sub_criteria IN ('SAM', 'SNM', 'NFR', 'TXF') OR t5.sub_criteria IS NULL)
    )
    OR (
        $P{subcriteria} = '1'
        AND t5.sub_criteria = 'SAM'
    )
    OR (
        $P{subcriteria} = '2'
        AND t5.sub_criteria IN ('SNM', 'NFR', 'TXF')
    ))
    AND ($P{receiptnumber} IS NULL OR $P{receiptnumber} = '' OR t4.rcpt_no LIKE '%' || $P{receiptnumber} || '%')
    AND ($P{pgtransactionid} IS NULL OR $P{pgtransactionid} = '' OR t2.pg_txn_id LIKE '%' || $P{pgtransactionid} || '%')
    AND ($P{statementno} IS NULL OR $P{statementno} = '' OR t0.stmt_no LIKE '%' || $P{statementno} || '%')
    and (
        $P{checkduplicate} IS NULL OR $P{checkduplicate} = '' OR
        ($P{checkduplicate} = 1 AND t10.mtt_pg_count > 1) OR 
        ($P{checkduplicate} = 0 AND t10.mtt_pg_count = 1)
    )
GROUP BY 
     ornno, rcptno, pgtxnid, rcptdt, stmtno, dtstatement, mdramt, rmsbatchnocr, rmsbatchnodr, txnamt, pgpymtamt;]]>
	</queryString>
	<field name="no" class="java.lang.Long">
		<property name="com.jaspersoft.studio.field.name" value="no"/>
		<property name="com.jaspersoft.studio.field.label" value="no"/>
	</field>
