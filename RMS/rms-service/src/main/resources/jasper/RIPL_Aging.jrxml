	<queryString language="SQL">
		<![CDATA[WITH cte AS (
    SELECT      
        t1.batch_no AS batchno,
        t1.fms_ref_no AS fmsrefno,
        t0.entity_type AS entitytype,
        t2.entity_nm AS entitynm,
        t0.txn_type AS txntype,
        t0.status AS status,
        t4.dt_txn AS eventdate,
        t0.accr_amt AS accramt,
        t0.dt_due AS dtdue,
        t3.rcpt_dt AS dtrcpt,
        t0.dt_impair AS dtimpair,
        t0.dt_writeoff AS dtwriteoff,
        CASE
            WHEN t0.dt_created = t0.dt_impair THEN '0'
            WHEN t0.dt_created = t0.dt_writeoff THEN '0'
            ELSE TO_CHAR(ABS(DATE(t0.dt_created) - DATE(t0.dt_due)) + 1)
        END AS agingstatus
    FROM
        rms_ripl t0
    LEFT OUTER JOIN
        rms_fms_jn_h t1 ON t1.attr_ext_ref_no LIKE 'PL-' || t0.ripl_id || '-%'
    LEFT OUTER JOIN
        rms_mtt_item t2 ON t0.entity_no = t2.entity_no
    LEFT OUTER JOIN
        rms_mtt_rcpt t3 ON t0.rcpt_no = t3.rcpt_no
    LEFT OUTER JOIN
        rms_ripl_a t4 ON t0.ripl_id = t4.ripl_id
    where
        
    DATE(t0.dt_created) <= MDY(MONTH(DATE($P{createddate})), DAY(DATE($P{createddate})), YEAR(DATE($P{createddate})))
    AND DATE(t0.dt_due) >= MDY(MONTH(DATE($P{duedatestart})), DAY(DATE($P{duedatestart})), YEAR(DATE($P{duedatestart})))
    AND DATE(t0.dt_due) <= MDY(MONTH(DATE($P{duedateend})), DAY(DATE($P{duedateend})), YEAR(DATE($P{duedateend})))
    AND (
            ($P{impairstatus} = 1 AND t0.status = 'IP')
            OR ($P{writeoffstatus} = 1 AND t0.status = 'WO')
            OR (t0.status NOT IN ('IP', 'WO'))
        )
    
    AND ($P{entitytype} IS NULL OR $P{entitytype} = '' OR t0.entity_type = $P{entitytype})
    AND ($P{entitynm} IS NULL OR $P{entitynm} = '' OR t2.entity_nm LIKE '%' || $P{entitynm} || '%')
    
    AND ($P{receiptdatestart} IS NULL OR $P{receiptdatestart} = '' OR DATE(t3.rcpt_dt) >= MDY(MONTH(DATE($P{receiptdatestart})), DAY(DATE($P{receiptdatestart})), YEAR(DATE($P{receiptdatestart}))))
    AND ($P{receiptdateend} IS NULL OR $P{receiptdateend} = '' OR DATE(t3.rcpt_dt) <= MDY(MONTH(DATE($P{receiptdateend})), DAY(DATE($P{receiptdateend})), YEAR(DATE($P{receiptdateend}))))
    
    AND ($P{impairdatestart} IS NULL OR $P{impairdatestart} = '' OR DATE(t0.dt_impair) >= MDY(MONTH(DATE($P{impairdatestart})), DAY(DATE($P{impairdatestart})), YEAR(DATE($P{impairdatestart}))))
    AND ($P{impairdateend} IS NULL OR $P{impairdateend} = '' OR DATE(t0.dt_impair) <= MDY(MONTH(DATE($P{impairdateend})), DAY(DATE($P{impairdateend})), YEAR(DATE($P{impairdateend}))))
    AND ($P{writeoffdatestart} IS NULL OR $P{writeoffdatestart} = '' OR DATE(t0.dt_writeoff) >= MDY(MONTH(DATE($P{writeoffdatestart})), DAY(DATE($P{writeoffdatestart})), YEAR(DATE($P{writeoffdatestart}))))
    AND ($P{writeoffdateend} IS NULL OR $P{writeoffdateend} = '' OR DATE(t0.dt_writeoff) <= MDY(MONTH(DATE($P{writeoffdateend})), DAY(DATE($P{writeoffdateend})), YEAR(DATE($P{writeoffdateend}))))
    GROUP BY 
        batchno, fmsrefno, entitytype, entitynm, txntype, status, eventdate, accramt, dtdue,
        dtrcpt, dtimpair, dtwriteoff, agingstatus
)

SELECT
    ROW_NUMBER() OVER (ORDER BY entitytype DESC) AS no,
    batchno,
    fmsrefno,
    entitytype,
    entitynm,
    txntype,
    status,
    eventdate,
    accramt,
    dtdue,
    dtrcpt,
    dtimpair,
    dtwriteoff,
    agingstatus,
    CASE WHEN TO_NUMBER(agingstatus) BETWEEN 1 AND 30 THEN accramt ELSE NULL END AS day30,
    CASE WHEN TO_NUMBER(agingstatus) BETWEEN 31 AND 60 THEN accramt ELSE NULL END AS day60,
    CASE WHEN TO_NUMBER(agingstatus) BETWEEN 61 AND 90 THEN accramt ELSE NULL END AS day90,
    CASE WHEN TO_NUMBER(agingstatus) BETWEEN 91 AND 120 THEN accramt ELSE NULL END AS day120,
    CASE WHEN TO_NUMBER(agingstatus) BETWEEN 121 AND 180 THEN accramt ELSE NULL END AS day180,
    CASE WHEN TO_NUMBER(agingstatus) BETWEEN 181 AND 360 THEN accramt ELSE NULL END AS day360,
    CASE WHEN TO_NUMBER(agingstatus) BETWEEN 361 AND 725 THEN accramt ELSE NULL END AS day725,
    CASE WHEN TO_NUMBER(agingstatus) > 725 THEN accramt ELSE NULL END AS day725
FROM
    cte;]]>
	</queryString>
