	</variable>
	<variable name="SumDay360" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{day360}]]></variableExpression>
	</variable>
	<variable name="SumDay725" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{day725}]]></variableExpression>
	</variable>
	<variable name="Variable_3" class="java.lang.String"/>
	<variable name="TotalRIPL" class="java.math.BigDecimal" incrementType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{day30} == null && $F{day60} == null && $F{day90} == null && $F{day120} == null && $F{day180} == null && $F{day360} == null && $F{day725} == null ? 
    null : 
    (
        ($F{day30} != null ? (java.math.BigDecimal) $F{day30} : java.math.BigDecimal.ZERO)
        .add($F{day60} != null ? (java.math.BigDecimal) $F{day60} : java.math.BigDecimal.ZERO)
        .add($F{day90} != null ? (java.math.BigDecimal) $F{day90} : java.math.BigDecimal.ZERO)
        .add($F{day120} != null ? (java.math.BigDecimal) $F{day120} : java.math.BigDecimal.ZERO)
        .add($F{day180} != null ? (java.math.BigDecimal) $F{day180} : java.math.BigDecimal.ZERO)
		.add($F{day360} != null ? (java.math.BigDecimal) $F{day360} : java.math.BigDecimal.ZERO)
		.add($F{day725} != null ? (java.math.BigDecimal) $F{day725} : java.math.BigDecimal.ZERO)
    )]]></variableExpression>
	</variable>
	<variable name="SumTotalRIPL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{TotalRIPL}]]></variableExpression>
	</variable>
