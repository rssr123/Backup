				<textElement markup="styled">
					<font isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA["Refund Date Range: " + DATEFORMAT(DATE(Integer.parseInt($P{datestart}.substring(0,4)), Integer.parseInt($P{datestart}.substring(5,7)), Integer.parseInt($P{datestart}.substring(8,10))), "dd MMM yyyy") + " to " + DATEFORMAT(DATE(Integer.parseInt($P{dateend}.substring(0,4)), Integer.parseInt($P{dateend}.substring(5,7)), Integer.parseInt($P{dateend}.substring(8,10))), "dd MMM yyyy")]]></textFieldExpression>
