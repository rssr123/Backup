			<textField>
				<reportElement x="680" y="30" width="300" height="20" uuid="71948bb9-f07c-4aef-9b0f-4279a7641bc5"/>
				<textElement markup="styled">
					<font isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA["Refund Type: " + 
    ($P{refundtype} == null ? "All" : 
        ($P{refundtype}.equals("RS01") ? "Refund Slip 01" :
        ($P{refundtype}.equals("RS02") ? "Refund Slip 02" :
        ($P{refundtype}.equals("DA") ? "Direct Appeal" :
        ($P{refundtype}.equals("CB") ? "Chargeback" :
        "Unknown Refund Type")))))]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="380" y="30" width="300" height="20" uuid="f33d44f5-7855-44d6-9bba-c490cc37e36f"/>
				<textFieldExpression><![CDATA["Refund Status: " + 
    ($P{refundstatus} == null ? "All" : 
        ($P{refundstatus}.equals("PFA") ? "Pending Finance Admin" :
        ($P{refundstatus}.equals("PBYM") ? "Pending BYM" :
        ($P{refundstatus}.equals("RS") ? "Refund Submitted" :
        ($P{refundstatus}.equals("RR") ? "Refund Rejected" :
        ($P{refundstatus}.equals("BE") ? "Bank Error" :
        ($P{refundstatus}.equals("RE") ? "Refund Expired" :
        ($P{refundstatus}.equals("AE") ? "Attempts Exceeded" :
        ($P{refundstatus}.equals("RG") ? "Refund Slip Generated" :
        ($P{refundstatus}.equals("PPG") ? "Pending PG" :
        ($P{refundstatus}.equals("PSME") ? "Pending SME" : 
        "Unknown Status")))))))))))]]></textFieldExpression>
			</textField>
